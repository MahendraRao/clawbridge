{
  "name": "clawbridge",
  "private": true,
  "version": "0.1.0",
  "description": "Beginner-friendly OpenClaw installer, verifier, and launcher",
  "packageManager": "pnpm@10.0.0",
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @clawbridge/desktop dev",
    "dev:api": "pnpm --filter @clawbridge/core dev",
    "dev": "concurrently -k \"pnpm dev:api\" \"pnpm dev:web\"",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "doctor": "pnpm --filter @clawbridge/core run doctor-demo"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
