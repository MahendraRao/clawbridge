{
  "name": "clawbridge",
  "private": true,
  "version": "0.1.0",
  "description": "Beginner-friendly OpenClaw web-assisted installer, verifier, and launcher",
  "packageManager": "pnpm@10.0.0",
  "engines": {
    "node": "24.x",
    "pnpm": "10.x"
  },
  "scripts": {
    "build": "pnpm -r build",
    "dev:web": "pnpm --filter @clawbridge/desktop dev",
    "dev:api": "pnpm --filter @clawbridge/core dev",
    "dev": "concurrently -k \"pnpm dev:api\" \"pnpm dev:web\"",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "doctor": "pnpm --filter @clawbridge/core run doctor-demo",
    "setup": "pnpm install"
  },
  "devDependencies": {
    "concurrently": "^9.1.2"
  }
}
